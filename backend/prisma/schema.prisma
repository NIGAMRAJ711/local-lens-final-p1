// LocalLens Database Schema
// Provider: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  TRAVELER
  GUIDE
  BOTH
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

enum BookingType {
  PRIVATE
  GROUP
  PHOTOGRAPHY
  CUSTOM
}

enum BookingDuration {
  ONE_HOUR
  HALF_DAY
  FULL_DAY
  CUSTOM
}

enum PaymentStatus {
  PENDING
  CAPTURED
  REFUNDED
  FAILED
}

enum ReelType {
  GUIDE_PROMO
  TRAVELER_EXPERIENCE
  HIDDEN_GEM
  FOOD_SPOT
  VIEWPOINT
  STREET_ART
  GENERAL
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  phone             String?            @unique
  passwordHash      String
  fullName          String
  avatarUrl         String?
  role              UserRole           @default(TRAVELER)
  isActive          Boolean            @default(true)
  isEmailVerified   Boolean            @default(false)
  isPhoneVerified   Boolean            @default(false)
  firebaseUid       String?            @unique
  referralCode      String             @unique @default(uuid())
  referredBy        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  guideProfile      GuideProfile?
  travelerProfile   TravelerProfile?
  bookingsAsGuide   Booking[]          @relation("GuideBookings")
  bookingsAsTraveler Booking[]         @relation("TravelerBookings")
  sentMessages      Message[]          @relation("SentMessages")
  receivedMessages  Message[]          @relation("ReceivedMessages")
  reviewsGiven      Review[]           @relation("ReviewsGiven")
  reviewsReceived   Review[]           @relation("ReviewsReceived")
  reels             Reel[]
  reelLikes         ReelLike[]
  reelComments      ReelComment[]
  notifications     Notification[]
  walletTransactions WalletTransaction[]
  groupTourMembers  GroupTourMember[]
  sosAlerts         SosAlert[]

  @@map("users")
}

// ─────────────────────────────────────────
// GUIDE PROFILE
// ─────────────────────────────────────────

model GuideProfile {
  id                  String             @id @default(uuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio                 String
  city                String
  country             String
  languages           String[]
  expertiseTags       String[]
  isPhotographer      Boolean            @default(false)
  isAvailable         Boolean            @default(false)
  
  // Pricing
  hourlyRate          Float
  halfDayRate         Float
  fullDayRate         Float
  photographyRate     Float?
  
  // Stats
  totalBookings       Int                @default(0)
  totalEarnings       Float              @default(0)
  avgRating           Float              @default(0)
  totalReviews        Int                @default(0)
  
  // Verification
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  idDocumentUrl       String?
  verifiedAt          DateTime?
  
  // Location
  latitude            Float?
  longitude           Float?
  lastLocationUpdate  DateTime?

  // Wallet
  walletBalance       Float              @default(0)

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relations
  hiddenGems          HiddenGem[]
  availability        GuideAvailability[]
  groupTours          GroupTour[]

  @@map("guide_profiles")
}

// ─────────────────────────────────────────
// TRAVELER PROFILE
// ─────────────────────────────────────────

model TravelerProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  interests       String[]
  homeCity        String?
  totalToursBooked Int      @default(0)
  loyaltyPoints   Int       @default(0)
  
  // Wallet
  walletBalance   Float     @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  bucketList      BucketListItem[]

  @@map("traveler_profiles")
}

// ─────────────────────────────────────────
// GUIDE AVAILABILITY
// ─────────────────────────────────────────

model GuideAvailability {
  id            String       @id @default(uuid())
  guideId       String
  guide         GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  date          DateTime
  startTime     String
  endTime       String
  isBooked      Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@map("guide_availability")
}

// ─────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────

model Booking {
  id              String          @id @default(uuid())
  guideId         String
  guide           User            @relation("GuideBookings", fields: [guideId], references: [id])
  travelerId      String
  traveler        User            @relation("TravelerBookings", fields: [travelerId], references: [id])
  
  bookingType     BookingType     @default(PRIVATE)
  duration        BookingDuration
  status          BookingStatus   @default(PENDING)
  
  date            DateTime
  startTime       String
  endTime         String?
  
  meetupLocation  String?
  meetupLat       Float?
  meetupLng       Float?
  
  specialRequests String?
  
  // Pricing
  basePrice       Float
  platformFee     Float
  totalAmount     Float
  
  // Payment
  paymentStatus   PaymentStatus   @default(PENDING)
  razorpayOrderId String?
  razorpayPaymentId String?
  
  // Escrow — released after tour complete
  escrowReleased  Boolean         @default(false)
  escrowReleasedAt DateTime?
  
  // Tracking
  guideStartedAt  DateTime?
  tourCompletedAt DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  messages        Message[]
  review          Review?
  payment         Payment?

  @@map("bookings")
}

// ─────────────────────────────────────────
// GROUP TOUR
// ─────────────────────────────────────────

model GroupTour {
  id            String            @id @default(uuid())
  guideId       String
  guide         GuideProfile      @relation(fields: [guideId], references: [id], onDelete: Cascade)
  
  title         String
  description   String
  city          String
  date          DateTime
  startTime     String
  duration      String
  
  maxMembers    Int               @default(6)
  pricePerPerson Float
  
  meetupPoint   String
  meetupLat     Float?
  meetupLng     Float?
  
  itinerary     String[]
  category      String[]
  
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  members       GroupTourMember[]

  @@map("group_tours")
}

model GroupTourMember {
  id          String    @id @default(uuid())
  groupTourId String
  groupTour   GroupTour @relation(fields: [groupTourId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  joinedAt    DateTime  @default(now())
  paymentStatus PaymentStatus @default(PENDING)

  @@unique([groupTourId, userId])
  @@map("group_tour_members")
}

// ─────────────────────────────────────────
// HIDDEN GEM
// ─────────────────────────────────────────

model HiddenGem {
  id          String       @id @default(uuid())
  guideId     String
  guide       GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)
  
  name        String
  description String
  category    String
  city        String
  latitude    Float
  longitude   Float
  
  // Locked until user books the guide
  isLocked    Boolean      @default(true)
  photos      String[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("hidden_gems")
}

// ─────────────────────────────────────────
// REEL
// ─────────────────────────────────────────

model Reel {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  videoUrl      String
  thumbnailUrl  String?
  caption       String?
  
  reelType      ReelType      @default(GENERAL)
  city          String?
  latitude      Float?
  longitude     Float?
  locationName  String?
  
  hasBookingCta Boolean       @default(false)
  
  views         Int           @default(0)
  likesCount    Int           @default(0)
  commentsCount Int           @default(0)
  
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  likes         ReelLike[]
  comments      ReelComment[]

  @@map("reels")
}

model ReelLike {
  id        String   @id @default(uuid())
  reelId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([reelId, userId])
  @@map("reel_likes")
}

model ReelComment {
  id        String   @id @default(uuid())
  reelId    String
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  comment   String
  createdAt DateTime @default(now())

  @@map("reel_comments")
}

// ─────────────────────────────────────────
// MESSAGE (In-App Chat)
// ─────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  content     String
  isRead      Boolean  @default(false)
  readAt      DateTime?
  
  createdAt   DateTime @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  reviewerId  String
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId  String
  reviewee    User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  
  rating      Float
  comment     String
  photos      String[]
  
  guideResponse String?
  respondedAt   DateTime?
  
  createdAt   DateTime @default(now())

  @@map("reviews")
}

// ─────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  
  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("payments")
}

// ─────────────────────────────────────────
// WALLET TRANSACTION
// ─────────────────────────────────────────

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  amount      Float
  type        String   // CREDIT | DEBIT
  description String
  bookingId   String?
  
  createdAt   DateTime @default(now())

  @@map("wallet_transactions")
}

// ─────────────────────────────────────────
// BUCKET LIST
// ─────────────────────────────────────────

model BucketListItem {
  id                String          @id @default(uuid())
  travelerProfileId String
  travelerProfile   TravelerProfile @relation(fields: [travelerProfileId], references: [id], onDelete: Cascade)
  
  city              String
  description       String?
  isCompleted       Boolean         @default(false)
  completedAt       DateTime?
  
  createdAt         DateTime        @default(now())

  @@map("bucket_list_items")
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────
// SOS ALERT
// ─────────────────────────────────────────

model SosAlert {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  latitude    Float
  longitude   Float
  bookingId   String?
  message     String?
  isResolved  Boolean  @default(false)
  
  createdAt   DateTime @default(now())

  @@map("sos_alerts")
}
