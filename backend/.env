# ════════════════════════════════════════════════════════════════
# LocalLens Backend — Environment Configuration
# ════════════════════════════════════════════════════════════════

PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Secrets — CHANGE IN PRODUCTION
JWT_SECRET=LocalLens_Super_Secret_JWT_Key_2024_Change_This
JWT_REFRESH_SECRET=LocalLens_Refresh_Secret_Key_2024_Change_This

# ─── DATABASE ────────────────────────────────────────────────────
# Set this to your Supabase or any PostgreSQL URL
# Get FREE database at: https://supabase.com (no credit card needed)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
#
DATABASE_URL=

# ─── FILE UPLOADS ─────────────────────────────────────────────────
# Free Cloudinary account: https://cloudinary.com
# Without this, files are saved locally in ./uploads/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── EMAIL (Password Reset) ────────────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
# Without this, reset token is shown in API response (dev mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# ─── PLATFORM ─────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
