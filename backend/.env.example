# ─── Server ───────────────────────────────
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Auth ─────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-too-different-string

# ─── Database (Production Only) ───────────
# For local dev, JSON files are used automatically - no DB needed!
# For production, set this to your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Cloudinary (REQUIRED for media persistence) ──────────────
# Without this, image/video uploads will fail.
# Get a free account at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (REQUIRED for password reset) ──────────────────────
# IMPORTANT: Password reset only works if SMTP is configured.
# Without SMTP, reset requests are silently ignored (no token is exposed).
# Use Gmail App Password or a transactional email service (Resend, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@locallens.app
