# ─── Server ───────────────────────────────
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Auth ─────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-too-different-string

# ─── Database (Production Only) ───────────
# For local dev, JSON files are used automatically - no DB needed!
# For production, set this to your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ─── Cloudinary (Optional - for media uploads) ────────────────
# Get free account at cloudinary.com
# REQUIRED for media persistence — get free account at cloudinary.com
# Without this, all uploads fail (no local disk storage on Render free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Required for password reset in production) ────────
# IMPORTANT: Without SMTP configured, password reset emails will NOT be sent.
# The reset token is NEVER exposed in the API response — configure SMTP to
# enable password reset functionality. Get a Gmail App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@locallens.app
